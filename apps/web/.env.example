# KeepTend Web — Config API environment variables
#
# NEXT_PUBLIC_API_KEY   — Anthropic API key served to the mobile app as the free-tier config.
#                         Get one at https://console.anthropic.com/
# NEXT_PUBLIC_PROVIDER  — AI provider for the free tier ("Anthropic" or "OpenAI").
#                         Defaults to "Anthropic" when omitted.
#                         Anthropic models used:
#                           text   → claude-haiku-4-5-20251001  (~95% cheaper than gpt-4o)
#                           vision → claude-sonnet-4-6           (cheaper than gpt-4o, vision-capable)

NEXT_PUBLIC_API_KEY=sk-ant-...
NEXT_PUBLIC_PROVIDER=Anthropic
